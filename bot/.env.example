# Telegram bot token from @BotFather
BOT_TOKEN=

# Only this Telegram chat id may use the bot (your personal chat id)
ADMIN_CHAT_ID=

# This backend's API
API_BASE_URL=http://127.0.0.1:8000

# The bot logs into the backend with these — same Marzban admin credentials
# already set in backend/.env, nothing separate to invent or keep in sync.
MARZBAN_USERNAME=sudo_admin_username
MARZBAN_PASSWORD=sudo_admin_password
