# Marzban panel this backend manages. MARZBAN_USERNAME/PASSWORD is a service account
# used only for this backend's own unattended calls (the nightly sync job, etc).
# It is NOT a separate dashboard password — logging into the dashboard/bot uses
# whatever admin credentials Marzban itself already accepts (checked live against
# Marzban's own /api/admin/token on every login, see app/routers/auth.py).
MARZBAN_BASE_URL=https://your-marzban-domain:port
MARZBAN_USERNAME=sudo_admin_username
MARZBAN_PASSWORD=sudo_admin_password

# Local database (SQLite for dev; swap to postgresql:// for production)
DATABASE_URL=sqlite:///./vpn.db

# Session length for dashboard/bot logins. No JWT_SECRET here on purpose — it's
# auto-generated into backend/.jwt_secret on first run.
JWT_EXPIRE_MINUTES=1440

# Telegram bot
BOT_TOKEN=
BOT_ADMIN_CHAT_ID=
BOT_API_BASE_URL=http://127.0.0.1:8000

# Sync job
SYNC_INTERVAL_MINUTES=60
